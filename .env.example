# Optional. Used by share links/QR codes in promo tools.
# Example: https://gamenight.no
NEXT_PUBLIC_SITE_URL=

# Optional. Preferred canonical origin for SEO tags (can differ from preview hosts).
# Example: https://gamenight.no
NEXT_PUBLIC_CANONICAL_ORIGIN=

# Optional. Base path when serving under a repository path (e.g. GitHub Pages).
# Example: /GameNight
NEXT_PUBLIC_BASE_PATH=

# Optional. Public donation endpoint.
# If empty, donation buttons show a friendly "not configured" message.
# Example: https://api.example.com/vipps/donate
NEXT_PUBLIC_DONATION_API_URL=
